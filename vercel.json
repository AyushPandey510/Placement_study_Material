{
  "version": 2,
  "buildCommand": "cd placement_prep/frontend && npm install && npm run build",
  "outputDirectory": "placement_prep/frontend/dist",
  "functions": {
    "api/index.py": {
      "includeFiles": "courses/**,assets/**,placement_prep/data/**"
    }
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "^/assets/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": ".*",
      "dest": "/index.html"
    }
  ]
}